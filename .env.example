# === Core ===
PORT=8080
NODE_ENV=production

# === TradingView Webhook Secret ===
# Set a shared secret to verify TradingView alerts
WEBHOOK_SECRET=your-webhook-secret-here

# === Market Data ===
# Yahoo Finance (free, no key needed)
# Binance API (for crypto)
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
# Forex API (free tier: https://exchangerate.host)
EXCHANGE_RATE_API_KEY=

# === Railway ===
# You shouldn't need to set these manually - Railway sets them
# RAILWAY_PUBLIC_DOMAIN=
# RAILWAY_PORT=

# === Alpaca Markets (for live/paper trading) ===
# Get keys from: https://alpaca.markets/
ALPACA_API_KEY_ID=
ALPACA_SECRET_KEY=
# Set ALPACA_PAPER=true for paper trading, false for live
ALPACA_PAPER=true

# === Strategy ===
# Initial strategy config path
STRATEGY_CONFIG_PATH=./data/strategy/config.yaml
