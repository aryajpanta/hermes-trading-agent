# ── Required ──
# Alpaca Markets API credentials
ALPACA_API_KEY_ID=your_key_here
ALPACA_SECRET_KEY=your_secret_here
ALPACA_PAPER=true                       # Set to "false" for LIVE trading

# Gemini API Key (needed for AI news sentiment analysis)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional ──
PORT=8080                               # Railway assigns this automatically
NODE_ENV=production                     # "development" or "production"
STRATEGY_CONFIG_PATH=data/strategy/config.yaml
PAPER_BALANCE_USD=100000                # Starting paper balance

# ── Automation ──
ENABLE_AUTOMATION=true                  # "false" disables background loops
AUTOMATION_INTERVAL_MS=60000            # Alert-monitor poll interval (default 60s)
REVIEW_INTERVAL_MS=86400000             # Review/optimize cycle interval (default 24h)
