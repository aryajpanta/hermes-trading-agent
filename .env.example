# ─────────────────────────────────────────────────────────────
# Unified Trading Intelligence — environment variables
# Copy to .env for local dev, or set in Railway dashboard
# ─────────────────────────────────────────────────────────────

# ── Required ──

# Alpaca Markets API credentials
ALPACA_API_KEY_ID=your_alpaca_key_id_here
ALPACA_SECRET_KEY=your_alpaca_secret_here
ALPACA_PAPER=true                          # Set to "false" for LIVE trading (requires approval)

# OpenCode Go API key (for AI news sentiment analysis) — https://opencode.ai/auth (subscribe to Go)
OPENCODE_API_KEY=your_opencode_go_api_key_here
OPENCODE_MODEL=mimo-v2.5                     # Xiaomi MiMo V2.5; any OpenCode Go model id
OPENCODE_REASONING_EFFORT=high              # low | medium | high | none
# OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1/chat/completions  # override gateway (e.g. Zen)

# X / Twitter sentiment (augments news headlines fed to the sentiment model)
ENABLE_X_SENTIMENT=true                     # "false" to disable X scraping
X_BACKEND=nitter                            # "nitter" (no install) | "cli" (agent-reach)
# Blend weights for the model's per-source sub-scores (X weighted heavier):
X_SENTIMENT_WEIGHT=2.0                       # weight of X-post sentiment
NEWS_SENTIMENT_WEIGHT=1.0                    # weight of news-headline sentiment
# X_ACCOUNTS=DeItaone,FirstSquawk,unusual_whales                  # finance handles to also pull
#
# Backend "nitter" — zero-install RSS scrape (public mirrors are often blocked):
# X_NITTER_INSTANCES=https://nitter.net,https://nitter.poast.org  # override mirrors
#
# Backend "cli" — agent-reach (https://github.com/Panniantong/Agent-Reach), reliable:
#   pipx install twitter-cli && agent-reach configure twitter-cookies "auth_token=..; ct0=.."
#   (use a BURNER X account — cookie scraping carries ban risk; avoid datacenter IPs)
# X_CLI_BIN=twitter                          # "twitter" (twitter-cli) | "opencli"
# TWITTER_AUTH_TOKEN=...                      # X cookie (from a burner account)
# TWITTER_CT0=...                            # X cookie

# ── Optional but recommended ──

# TradingView webhook secret (HMAC-SHA256)
WEBHOOK_SECRET=your_random_secret_here

# ── Server ──

PORT=8000                                  # Railway assigns this automatically
HOST=0.0.0.0
LOG_LEVEL=INFO
DEV=false

# ── Automation ──

ENABLE_AUTOMATION=true                     # Set to "false" to disable background loops
AUTOMATION_INTERVAL_MS=60000               # Tick loop interval (default: 60s)
REVIEW_INTERVAL_MS=86400000                # Review/optimize cycle (default: 24h)

# Autonomous entries (the loop opens new positions via the DecisionEngine)
ENABLE_AUTO_ENTRIES=true                   # "false" = manage existing positions only
ENTRY_SCAN_INTERVAL_MS=900000              # How often to scan for new entries (default: 15m)
MAX_NEW_ENTRIES_PER_SCAN=3                 # Cap new positions opened per scan
ENTRY_SCAN_PERIOD=1y                       # OHLCV history window fed to strategies

# ── Data ──

DATA_DIR=data                              # Persistent data directory
PAPER_BALANCE_USD=100000                   # Starting paper balance
STRATEGY_CONFIG_PATH=data/strategy/config.yaml
PAPER_PORTFOLIO_PATH=data/paper_portfolio.json
